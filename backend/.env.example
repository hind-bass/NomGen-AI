# ─── NomGen Mode B — Clés API LLM ───────────────────────────────────────────
# Copiez ce fichier en .env et remplissez les clés des modèles que vous voulez utiliser.
# NE COMMITEZ JAMAIS le fichier .env (il est dans .gitignore).

# OpenAI (gpt-4o-mini, gpt-4o)
OPENAI_API_KEY=your_openai_api_key_here

# Mistral AI (mistral-small, mistral-large)
MISTRAL_API_KEY=your_mistral_api_key_here

# DeepSeek (deepseek-chat)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# HuggingFace (acegpt, jais)
HUGGINGFACE_API_KEY=your_huggingface_token_here

# Allam arabe via IBM watsonx
WATSONX_API_KEY=your_watsonx_api_key_here
WATSONX_PROJECT_ID=your_project_id_here

# Fanar arabe (Qatar)
FANAR_API_KEY=your_fanar_api_key_here

# Ollama local — modèles open source pour Mode B (naming FR/AR)
OLLAMA_BASE_URL=http://localhost:11434
