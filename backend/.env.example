# ─── NomGen Mode B — Clés API LLM ───────────────────────────────────────────
# Copiez ce fichier en .env et remplissez les clés des modèles que vous voulez utiliser.
# Seuls les modèles avec clés configurées (ou Ollama local) apparaîtront comme disponibles.

# OpenAI (gpt-4o-mini, gpt-4o)
OPENAI_API_KEY=sk-...

# Mistral AI (mistral-small, mistral-large)
MISTRAL_API_KEY=...

# DeepSeek (deepseek-chat)
DEEPSEEK_API_KEY=...

# HuggingFace (acegpt, jais)
HUGGINGFACE_API_KEY=hf_...

# Allam arabe via IBM watsonx
WATSONX_API_KEY=...
WATSONX_PROJECT_ID=...

# Fanar arabe (Qatar)
FANAR_API_KEY=...

# Ollama local (optionnel — défaut : http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434
